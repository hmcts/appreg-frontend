{
  "useCSRFProtection": true,
  "appInsights": {
    "instrumentationKey": false
  },
  "security": {
    "referrerPolicy": "same-origin",
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true
    }
  },
  "secrets": {
    "appreg": {
      "azure-app-id-fe": "dummyClientId",
      "azure-tenant-id-fe": "dummyTenantId",
      "azure-client-secret-fe": "dummyClientSecret",
      "redis-access-key": "dummyRedisAccessKey",
      "app-insights-connection-string-fe": "dummyInstrumentationKey",
      "app-session-secret-fe": "dummySessionSecret",
      "TEST-USER1-EMAIL": "dummyTestUser1Email",
      "TEST-USER2-EMAIL": "dummyTestUser2Email",
      "TEST-USER3-EMAIL": "dummyTestUser3Email",
      "TEST-ADMIN1-EMAIL": "dummyTestAdmin1Email",
      "TEST-ADMIN2-EMAIL": "dummyTestAdmin2Email",
      "TEST-ADMIN3-EMAIL": "dummyTestAdmin3Email",
      "TEST-USERS-PASSWORD": "dummyTestUserPassword"
    }
  },
  "auth": {
    "scopes": [
      "openid",
      "profile",
      "email",
      "offline_access"
    ]
  },
  "api": {
    "baseUrl": "http://localhost:4550"
    // "baseUrl": "https://appreg-api.staging.platform.hmcts.net"
  },
  "session": {
    "cookieName": "appreg.sid",
    "secure": false
  }
}