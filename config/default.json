{
  "useCSRFProtection": true,
  "appInsights": {
    "instrumentationKey": false
  },
  "security": {
    "referrerPolicy": "same-origin",
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true
    }
  },
  "secrets": {
    "appreg": {
      "azure-app-id-fe": "dummyClientId",
      "azure-tenant-id-fe": "dummyTenantId",
      "azure-client-secret-fe": "dummyClientSecret",
      "app-insights-connection-string-fe": "dummyInstrumentationKey"
    }
  },
  "auth": {
    "redirectUri": "http://localhost:4000/sso/login-callback",
    "postLogoutRedirectUri": "http://localhost:4000/login",
    "scopes": [
      "openid",
      "profile",
      "email",
      "offline_access"
    ]
  },
  "session": {
    "cookieName": "appreg.sid",
    "secret": "change-me-in-env",
    "secure": false
  },
  "api": {
    "baseUrl": "http://localhost:4550"
  }
}
