{
  "priority": 2,
  "request": {
    "method": "GET",
    "urlPathPattern": "/application-codes/[^/]+",
    "headers": {
      "Accept": { "absent": true }
    }
  },
  "response": {
    "status": 406,
    "headers": { "Content-Type": "application/problem+json" },
    "bodyFileName": "errors/not-acceptable.json"
  }
}
