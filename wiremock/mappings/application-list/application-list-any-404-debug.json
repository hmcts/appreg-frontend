{
  "priority": 3,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists(/[0-9a-f-]{36}(/print)?)?",
    "headers": {
      "X-Debug-Not-Found": {
        "equalTo": "true"
      }
    }
  },
  "response": {
    "status": 404,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": [
      "response-template"
    ],
    "bodyFileName": "errors/not-found.json"
  }
}
