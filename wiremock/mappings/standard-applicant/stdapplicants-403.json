{
  "name": "Standard Applicants – 403 Forbidden",
  "priority": 2,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/(?i)standard-applicants(/.*)?",
    "headers": {
      "Authorization": {
        "matches": "Bearer forbidden.*"
      }
    }
  },
  "response": {
    "status": 403,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": [
      "response-template"
    ],
    "bodyFileName": "errors/forbidden.json"
  }
}
