{
  "name": "Standard Applicants – GET detail – 200",
  "priority": 5,
  "request": {
    "method": "GET",
    "urlPathPattern": "/(?i)standard-applicants/[^/]+",
    "headers": {
      "Accept": {
        "contains": "application/vnd.hmcts.appreg.v1+json"
      },
      "Authorization": {
        "matches": "Bearer .+"
      }
    },
    "queryParameters": {
      "date": {
        "matches": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/vnd.hmcts.appreg.v1+json",
      "Vary": "Accept",
      "X-Stub": "stdapplicants-detail-200"
    },
    "transformers": ["response-template"],
    "body": "{\n  \"code\": \"{{upper request.pathSegments.[1]}}\",\n  \"fullName\": {\n    \"title\": \"Mr\",\n    \"firstName\": \"Alex\",\n    \"middleNames\": null,\n    \"lastName\": \"Taylor\"\n  },\n  \"contactDetails\": {\n    \"addressLine1\": \"1 Crown Sq\",\n    \"addressLine2\": \"\",\n    \"addressLine3\": \"Manchester\",\n    \"postCode\": \"M1 1AA\",\n    \"email\": \"alex.taylor@example.test\",\n    \"phoneNumber\": \"+44 161 000 0000\"\n  },\n  \"startDate\": \"2020-01-01\",\n  \"endDate\": null\n}\n"
  }
}
