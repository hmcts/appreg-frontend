{
  "name": "Entries – 500 (debug toggle)",
  "priority": 0,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries(/.*)?",
    "headers": { "X-Debug-Failure": { "equalTo": "true" } }
  },
  "response": {
    "status": 500,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/internal-server-error.json"
  }
}
