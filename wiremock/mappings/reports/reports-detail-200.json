{
  "name": "Reports – GET detail – 200",
  "priority": 5,
  "request": {
    "method": "GET",
    "urlPathPattern": "/reports/[0-9a-f-]{8}-[0-9a-f-]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}",
    "headers": {
      "Accept": { "contains": "application/vnd.hmcts.appreg.v1+json" },
      "Authorization": { "matches": "Bearer .+" }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/vnd.hmcts.appreg.v1+json",
      "Vary": "Accept",
      "X-Stub": "reports-detail-200"
    },
    "transformers": ["response-template"],
    "body": "{\n  \"id\": \"{{request.pathSegments.[1]}}\",\n  \"reportType\": \"APPLICATIONS_BY_DAY\",\n  \"parameters\": { \"fromDate\": \"2025-11-01\", \"toDate\": \"2025-11-30\" },\n  \"requestedAt\": \"{{now offset='-PT30M' format='yyyy-MM-dd'T'HH:mm:ssXXX'}}\",\n  \"status\": \"{{#if request.headers.X-Debug-Status}}{{request.headers.X-Debug-Status}}{{else}}COMPLETED{{/if}}\",\n  \"downloadUrl\": {{#if (equals (default request.headers.X-Debug-Status.[0] 'COMPLETED') 'COMPLETED')}}\"/reports/{{request.pathSegments.[1]}}/content\"{{else}}null{{/if}},\n  \"generatedAt\": {{#if (equals (default request.headers.X-Debug-Status.[0] 'COMPLETED') 'COMPLETED')}}\"{{now format='yyyy-MM-dd'T'HH:mm:ssXXX'}}\"{{else}}null{{/if}}\n}\n"
  }
}
