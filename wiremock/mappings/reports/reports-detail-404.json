{
  "name": "Reports – 404 Not Found (debug toggle)",
  "priority": 4,
  "request": {
    "method": "GET",
    "urlPathPattern": "/reports/[0-9a-f-]{36}",
    "headers": {
      "Authorization": { "matches": "Bearer .+" },
      "X-Debug-Not-Found": { "equalTo": "true" }
    }
  },
  "response": {
    "status": 404,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/not-found.json"
  }
}
