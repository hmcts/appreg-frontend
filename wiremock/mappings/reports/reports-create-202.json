{
  "name": "Reports – POST create – 202",
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPath": "/reports",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "Content-Type": {
        "matches": "(application/vnd\\.hmcts\\.appreg\\.v1\\+json|application/json|application/.+\\+json)"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.reportType"
      },
      {
        "matchesJsonPath": "$.fromDate"
      },
      {
        "matchesJsonPath": "$.toDate"
      }
    ]
  },
  "response": {
    "status": 202,
    "headers": {
      "Content-Type": "application/vnd.hmcts.appreg.v1+json",
      "Vary": "Accept",
      "Location": "/reports/{{randomValue type='UUID'}}",
      "X-Stub": "reports-create-202"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{\n  \"id\": \"{{randomValue type='UUID'}}\",\n  \"reportType\": \"{{jsonPath request.body '$.reportType'}}\",\n  \"parameters\": {\n    \"fromDate\": \"{{jsonPath request.body '$.fromDate'}}\",\n    \"toDate\": \"{{jsonPath request.body '$.toDate'}}\"\n  },\n  \"requestedAt\": \"{{now format='yyyy-MM-dd'T'HH:mm:ssXXX'}}\",\n  \"status\": \"PENDING\"\n}\n"
  }
}
