{
  "name": "Actions – Bulk Upload – 413 (debug toggle)",
  "priority": 3,
  "request": {
    "method": "POST",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/actions/bulk-upload",
    "headers": {
      "Authorization": { "matches": "Bearer .+" },
      "X-Debug-Payload-Too-Large": { "equalTo": "true" }
    }
  },
  "response": {
    "status": 413,
    "headers": { "Content-Type": "application/problem+json" },
    "body": "{ \"type\":\"about:blank\",\"title\":\"Payload Too Large\",\"status\":413,\"detail\":\"CSV exceeds the maximum allowed size.\",\"path\":\"{{request.path}}\" }"
  }
}
