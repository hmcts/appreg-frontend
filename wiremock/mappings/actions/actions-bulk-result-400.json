{
  "name": "Actions – Bulk Result – 400 missing fields",
  "priority": 4,
  "request": {
    "method": "POST",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/actions/bulk-result",
    "headers": { "Authorization": { "matches": "Bearer .+" } },
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.entryIds", "absent": true } },
      {
        "or": [
          { "matchesJsonPath": { "expression": "$.result", "absent": true } },
          {
            "matchesJsonPath": {
              "expression": "$.result.resultCode",
              "absent": true
            }
          }
        ]
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/bad-request.json"
  }
}
