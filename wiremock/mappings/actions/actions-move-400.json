{
  "name": "Actions – Move – 400 missing fields",
  "priority": 4,
  "request": {
    "method": "POST",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/actions/move-entries",
    "headers": { "Authorization": { "matches": "Bearer .+" } },
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.targetListId", "absent": true } },
      { "matchesJsonPath": { "expression": "$.entryIds", "absent": true } }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/problem+json" },
    "bodyFileName": "errors/bad-request.json"
  }
}
