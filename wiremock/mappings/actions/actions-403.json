{
  "name": "Actions – 403 Forbidden",
  "priority": 2,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/actions(/.*)?",
    "headers": { "Authorization": { "matches": "Bearer forbidden.*" } }
  },
  "response": {
    "status": 403,
    "headers": { "Content-Type": "application/problem+json" },
    "body": "{ \"type\":\"about:blank\",\"title\":\"Forbidden\",\"status\":403,\"detail\":\"Access denied.\",\"path\":\"{{request.path}}\" }"
  }
}
