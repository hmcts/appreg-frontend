{
  "name": "Jobs – 401 Unauthorized",
  "priority": 3,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/jobs(/.*)?",
    "headers": {
      "Authorization": {
        "absent": true
      }
    }
  },
  "response": {
    "status": 401,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": [
      "response-template"
    ],
    "bodyFileName": "errors/unauthorized.json"
  }
}
