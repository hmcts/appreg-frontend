{
  "name": "Jobs – 500 (debug toggle)",
  "priority": 0,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/jobs(/.*)?",
    "headers": {
      "X-Debug-Failure": {
        "equalTo": "true"
      }
    }
  },
  "response": {
    "status": 500,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": ["response-template"],
    "bodyFileName": "errors/internal-server-error.json"
  }
}
