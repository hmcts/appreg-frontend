{
  "priority": 100,
  "request": {
    "method": "GET",
    "urlPathPattern": "/application-codes/[^/]+",
    "headers": {
      "Accept": { "contains": "application/vnd.hmcts.appreg.v1+json" },
      "Authorization": { "matches": "Bearer .+" }
    }
  },
  "response": {
    "status": 404,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/not-found.json"
  }
}
