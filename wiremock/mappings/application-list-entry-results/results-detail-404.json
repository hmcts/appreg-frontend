{
  "name": "Entry Results – 404 Not Found (debug toggle)",
  "priority": 2,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results/[0-9a-f-]{36}",
    "headers": {
      "Authorization": { "matches": "Bearer .+" },
      "X-Debug-Not-Found": { "equalTo": "true" }
    }
  },
  "response": {
    "status": 404,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "body": "{ \"type\":\"about:blank\",\"title\":\"Not Found\",\"status\":404,\"detail\":\"Result '{{request.pathSegments.[5]}}' was not found.\",\"path\":\"{{request.path}}\",\"timestamp\":\"{{now format='yyyy-MM-dd'T'HH:mm:ssXXX'}}\",\"traceId\":\"{{randomValue length=12 type='ALPHANUMERIC'}}\" }"
  }
}
