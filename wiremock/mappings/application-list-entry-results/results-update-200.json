{
  "name": "Entry Results – PUT update – 200",
  "priority": 5,
  "request": {
    "method": "PUT",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results/[0-9a-f-]{36}",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "Content-Type": {
        "matches": "(application/vnd\\.hmcts\\.appreg\\.v1\\+json|application/json|application/.+\\+json)"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.resultCode"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/vnd.hmcts.appreg.v1+json",
      "Vary": "Accept",
      "X-Stub": "results-update-200"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{\n  \"id\": \"{{request.pathSegments.[5]}}\",\n  \"entryId\": \"{{request.pathSegments.[3]}}\",\n  \"resultCode\": \"{{jsonPath request.body '$.resultCode'}}\",\n  \"wordingFields\": {{#if (jsonPath request.body '$.wordingFields')}}{{{jsonPath request.body '$.wordingFields'}}}{{else}}[]{{/if}}\n}\n"
  }
}
