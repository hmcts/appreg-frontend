{
  "name": "Entry Results – 400 missing resultCode",
  "priority": 4,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results(/[0-9a-f-]{36})?",
    "headers": { "Authorization": { "matches": "Bearer .+" } },
    "bodyPatterns": [
      { "matchesJsonPath": { "expression": "$.resultCode", "absent": true } }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/bad-request.json"
  }
}
