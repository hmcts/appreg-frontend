{
  "name": "Entry Results – 403 Forbidden",
  "priority": 3,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results(/.*)?",
    "headers": { "Authorization": { "matches": "Bearer forbidden.*" } }
  },
  "response": {
    "status": 403,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/forbidden.json"
  }
}
