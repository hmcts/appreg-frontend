{
  "name": "Entry Results – 406 Not Acceptable",
  "priority": 3,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results(/.*)?",
    "headers": { "Accept": { "doesNotContain": "application/vnd.hmcts.appreg.v1+json" } }
  },
  "response": {
    "status": 406,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "body": "{ \"type\":\"about:blank\",\"title\":\"Not Acceptable\",\"status\":406,\"detail\":\"Set Accept: application/vnd.hmcts.appreg.v1+json.\",\"path\":\"{{request.path}}\",\"timestamp\":\"{{now format='yyyy-MM-dd'T'HH:mm:ssXXX'}}\",\"traceId\":\"{{randomValue length=12 type='ALPHANUMERIC'}}\" }"
  }
}
