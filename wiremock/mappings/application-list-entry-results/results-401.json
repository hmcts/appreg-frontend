{
  "name": "Entry Results – 401 Unauthorized",
  "priority": 3,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results(/.*)?",
    "headers": { "Authorization": { "absent": true } }
  },
  "response": {
    "status": 401,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/unauthorized.json"
  }
}
