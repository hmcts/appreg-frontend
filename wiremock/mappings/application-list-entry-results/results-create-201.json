{
  "name": "Entry Results – POST create – 201",
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPathPattern": "/application-lists/[0-9a-f-]{36}/entries/[0-9a-f-]{36}/results",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "Content-Type": {
        "matches": "(application/vnd\\.hmcts\\.appreg\\.v1\\+json|application/json|application/.+\\+json)"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.resultCode"
      }
    ]
  },
  "response": {
    "status": 201,
    "headers": {
      "Content-Type": "application/vnd.hmcts.appreg.v1+json",
      "Vary": "Accept",
      "Location": "/application-lists/{{request.pathSegments.[1]}}/entries/{{request.pathSegments.[3]}}/results/{{randomValue type='UUID'}}",
      "X-Stub": "results-create-201"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{\n  \"id\": \"{{randomValue type='UUID'}}\",\n  \"entryId\": \"{{request.pathSegments.[3]}}\",\n  \"resultCode\": \"{{jsonPath request.body '$.resultCode'}}\",\n  \"wordingFields\": {{#if (jsonPath request.body '$.wordingFields')}}{{{jsonPath request.body '$.wordingFields'}}}{{else}}[]{{/if}}\n}\n"
  }
}
