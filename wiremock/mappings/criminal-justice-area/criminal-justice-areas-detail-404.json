{
  "name": "CJA – GET detail – 404 (debug toggle)",
  "priority": 4,
  "request": {
    "method": "GET",
    "urlPathPattern": "/(?i)criminal-justice-areas/[^/]+",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "X-Debug-Not-Found": {
        "equalTo": "true"
      }
    }
  },
  "response": {
    "status": 404,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": ["response-template"],
    "bodyFileName": "errors/not-found.json"
  }
}
