{
  "name": "CJA – 500 (debug toggle)",
  "priority": 0,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/(?i)criminal-justice-areas(/.*)?",
    "headers": {
      "X-Debug-Failure": {
        "equalTo": "true"
      }
    }
  },
  "response": {
    "status": 500,
    "headers": {
      "Content-Type": "text/plain"
    },
    "bodyFileName": "errors/internal-server-error.json"
  }
}
