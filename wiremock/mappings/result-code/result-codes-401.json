{
  "name": "Result Codes – 401 Unauthorized",
  "priority": 2,
  "request": {
    "method": "ANY",
    "urlPathPattern": "/(?i)result-codes(/.*)?",
    "headers": {
      "Authorization": {
        "absent": true
      }
    }
  },
  "response": {
    "status": 401,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": ["response-template"],
    "bodyFileName": "errors/unauthorized.json"
  }
}
