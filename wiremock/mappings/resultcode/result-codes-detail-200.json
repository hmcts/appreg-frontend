{
  "name": "Result Codes – GET detail – 200",
  "priority": 5,
  "request": {
    "method": "GET",
    "urlPathPattern": "/(?i)result-codes/[^/]+",
    "headers": {
      "Accept": {
        "contains": "application/vnd.hmcts.appreg.v1+json"
      },
      "Authorization": {
        "matches": "Bearer .+"
      }
    },
    "queryParameters": {
      "date": {
        "matches": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/vnd.hmcts.appreg.v1+json",
      "Vary": "Accept",
      "X-Stub": "result-codes-detail-200"
    },
    "transformers": [
      "response-template"
    ],
    "body": "{\n  \"resultCode\": \"{{upper request.pathSegments.[1]}}\",\n  \"title\": \"Result {{upper request.pathSegments.[1]}}\",\n  \"wording\": \"Result '{{upper request.pathSegments.[1]}}' applied on {{request.query.date.[0]}}.\",\n  \"startDate\": \"2010-01-01\",\n  \"endDate\": null\n}\n"
  }
}
