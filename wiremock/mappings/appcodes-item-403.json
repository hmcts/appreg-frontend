{
  "priority": 2,
  "request": {
    "method": "GET",
    "urlPathPattern": "/application-codes/[^/]+",
    "headers": {
      "Authorization": { "matches": "Bearer\\s+forbidden.*" }
    }
  },
  "response": {
    "status": 403,
    "headers": { "Content-Type": "application/problem+json" },
    "transformers": ["response-template"],
    "bodyFileName": "errors/forbidden.json"
  }
}
