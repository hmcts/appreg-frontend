{
  "name": "Court Locations – GET detail – 400 missing/invalid date",
  "priority": 4,
  "request": {
    "method": "GET",
    "urlPathPattern": "/(?i)court-locations/[^/]+",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      }
    },
    "queryParameters": {
      "date": {
        "absent": true
      }
    }
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": [
      "response-template"
    ],
    "bodyFileName": "errors/bad-request.json"
  }
}
