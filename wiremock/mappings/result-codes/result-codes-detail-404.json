{
  "name": "Result Codes – GET detail – 404 (debug toggle)",
  "priority": 4,
  "request": {
    "method": "GET",
    "urlPathPattern": "/(?i)result-codes/[^/]+",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "X-Debug-Not-Found": {
        "equalTo": "true"
      }
    },
    "queryParameters": {
      "date": {
        "matches": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  },
  "response": {
    "status": 404,
    "headers": {
      "Content-Type": "application/problem+json"
    },
    "transformers": ["response-template"],
    "bodyFileName": "errors/not-found.json"
  }
}
