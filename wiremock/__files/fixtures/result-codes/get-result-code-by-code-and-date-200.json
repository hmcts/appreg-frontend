{
  "resultCode": "{{upper request.pathSegments.[1]}}",
  "title": "Result {{upper request.pathSegments.[1]}}",
  "wording": {
    "template": "Result '{{upper request.pathSegments.[1]}}' applied on \\{\\{ Date \\}\\} at \\{\\{ Location \\}\\}.",
    "substitution-key-constraints": [
      {
        "key": "Date",
        "value": "{{#if request.query.date}}{{request.query.date.[0]}}{{/if}}",
        "constraint": {
          "type": "DATE",
          "length": 10
        }
      },
      {
        "key": "Location",
        "value": "London",
        "constraint": {
          "type": "TEXT",
          "length": 60
        }
      }
    ]
  },
  "startDate": "2010-01-01",
  "endDate": null
}
