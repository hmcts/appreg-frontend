#!groovy

@Library("Infrastructure")

def type = "angular"
def product = "appreg"
def component = "frontend"

def branchesToSync = ['demo', 'ithc']

def secrets = [
    'appreg-${env}': [
        secret('POSTGRES-USER', 'DB_USER'),
        secret('POSTGRES-PASS', 'DB_PASSWORD'),
        secret('POSTGRES-HOST', 'DB_HOST'),
        secret('POSTGRES-PORT', 'DB_PORT'),
        secret('POSTGRES-DATABASE', 'DB_NAME'),
        secret('TEST-USER1-EMAIL', 'TEST_USER1_EMAIL'),
        secret('TEST-USER2-EMAIL', 'TEST_USER2_EMAIL'),
        secret('TEST-USER3-EMAIL', 'TEST_USER3_EMAIL'),
        secret('TEST-ADMIN1-EMAIL', 'TEST_ADMIN1_EMAIL'),
        secret('TEST-ADMIN2-EMAIL', 'TEST_ADMIN2_EMAIL'),
        secret('TEST-ADMIN3-EMAIL', 'TEST_ADMIN3_EMAIL'),
        secret('TEST-USERS-PASSWORD', 'TEST_USERS_PASSWORD'),
    ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [
        $class     : 'AzureKeyVaultSecret',
        secretType : 'Secret',
        name       : secretName,
        version    : '',
        envVariable: envVar
    ]
}

withPipeline(type, product, component) {

    loadVaultSecrets(secrets)
    enableSlackNotifications('#appreg-builds')

    def appObjectId = '20e4de40-7aee-45b1-895b-cb77546763dc'

    def manageRedirectUri = { String url, String mode ->
      echo "manageRedirectUri: mode=${mode}, url=${url}, subscription=${env.SUBSCRIPTION_NAME}"

      def az = new uk.gov.hmcts.contino.azure.Az(this, env.SUBSCRIPTION_NAME)

      def currentUrisJson = az.az(
        "rest --method GET --url 'https://graph.microsoft.com/v1.0/applications/${appObjectId}' --query 'web.redirectUris' -o json"
      )

      echo "manageRedirectUri: Graph GET returned length=${currentUrisJson?.size() ?: 0}"
      echo "manageRedirectUri: Graph GET preview=${currentUrisJson?.take(300) ?: 'null'}"

      withEnv([
        "CURRENT_URIS_JSON=${currentUrisJson}",
        "TARGET_URL=${url}",
        "MODE=${mode}"
      ]) {
        def out = sh(
          script: """
            bash -lc '
              set -euo pipefail
              set -x

              echo "DEBUG: MODE=\$MODE"
              echo "DEBUG: TARGET_URL=\$TARGET_URL"

              current="\${CURRENT_URIS_JSON:-null}"
              echo "DEBUG: CURRENT_URIS_JSON raw length=\${#current}"
              echo "DEBUG: CURRENT_URIS_JSON preview=\${current:0:300}"

              if [ "\$current" = "null" ] || [ -z "\$current" ]; then
                echo "DEBUG: CURRENT is null/empty -> using []"
                current="[]"
              fi

              echo "DEBUG: Validating JSON with jq..."
              if ! echo "\$current" | jq -e . >/dev/null 2>&1; then
                echo "ERROR: CURRENT is not valid JSON!" >&2
                echo "\$current" | head -c 1000 >&2 || true
                exit 3
              fi

              echo "DEBUG: CURRENT redirectUris (pretty, first 50 lines):"
              echo "\$current" | jq . | sed -n "1,50p"

              echo "DEBUG: Checking whether URL already present..."
              if echo "\$current" | jq -e --arg url "\$TARGET_URL" '"'"'any(. == $url)'"'"' >/dev/null; then
                echo "DEBUG: URL already present -> NO_CHANGE"
                echo "NO_CHANGE"
                exit 0
              else
                echo "DEBUG: URL not present"
              fi

              case "\$MODE" in
                add)
                  echo "DEBUG: Adding URL..."
                  updated=\$(echo "\$current" | jq --arg url "\$TARGET_URL" '"'"'. + [$url] | unique'"'"')
                  ;;
                remove)
                  echo "DEBUG: Removing URL..."
                  updated=\$(echo "\$current" | jq --arg url "\$TARGET_URL" '"'"'map(select(. != $url))'"'"')
                  ;;
                *)
                  echo "ERROR: Invalid MODE: \$MODE" >&2
                  exit 2
                  ;;
              esac

              echo "DEBUG: UPDATED preview:"
              echo "\$updated" | jq . | sed -n "1,50p"

              body=\$(jq -cn --argjson uris "\$updated" '"'"'{web:{redirectUris:$uris}}'"'"')
              echo "DEBUG: PATCH body preview:"
              echo "\$body" | jq . | sed -n "1,80p"

              echo "DEBUG: Performing Graph PATCH..."
              env AZURE_CONFIG_DIR=/opt/jenkins/.azure-${env.SUBSCRIPTION_NAME} az rest \\
                --method PATCH \\
                --url "https://graph.microsoft.com/v1.0/applications/${appObjectId}" \\
                --headers "Content-Type=application/json" \\
                --body "\$body" \\
                -o none

              echo "DEBUG: PATCH completed"
              echo "CHANGED"
            '
          """,
          returnStdout: true
        ).trim()

        echo "manageRedirectUri: shell output => ${out}"
        return out
      }
    }

    before('functionalTest:dev') {
      echo "Setting up redirect URI for preview environment"

      if (!env.TEST_URL) {
        error("TEST_URL missing from environment")
      }

      echo "Whitelisting redirect URI for PR: ${env.TEST_URL}"
      def out = manageRedirectUri(env.TEST_URL, 'add')
      env.REDIRECT_URI_ADDED = out.contains('CHANGED') ? 'true' : 'false'
    }

    afterAlways('functionalTest:dev') {
      // If you ONLY want to remove after success, keep the SUCCESS check:
      def result = (currentBuild.currentResult ?: 'SUCCESS')
      if (result == 'SUCCESS' && env.REDIRECT_URI_ADDED == 'true') {
        echo "Removing redirect URI for PR: ${env.TEST_URL}"
        manageRedirectUri(env.TEST_URL, 'remove')
      }
    }

    after('functionalTest:aat') {
        script {
            def testResult = sh(script: 'yarn test:functional', returnStatus: true)

            sh 'node cypress/scripts/generate-reports.js || true'

            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/**/*'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/screenshots/**/*.png'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/junit/**/*.xml'

            junit allowEmptyResults: true, testResults: 'cypress/reports/junit/**/*.xml'

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports/cucumber-html',
                reportFiles: 'index.html',
                reportName: 'Cucumber Report',
                reportTitles: 'Cucumber Test Report'
            ])

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports',
                reportFiles: 'mochawesome.html',
                reportName: 'Mochaware Report',
                reportTitles: 'Mochawesome Test Report'
            ])

            if (testResult != 0) {
                error("Smoke tests failed with exit code ${testResult}")
            }
        }
    }

    syncBranchesWithMaster(branchesToSync)
}
