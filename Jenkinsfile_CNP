#!groovy

@Library("Infrastructure")

def type = "angular"
def product = "appreg"
def component = "frontend"

def branchesToSync = ['demo', 'ithc']

def secrets = [
        'appreg-${env}': [
                secret('POSTGRES-USER', 'DB_USER'),
                secret('POSTGRES-PASS', 'DB_PASSWORD'),
                secret('POSTGRES-HOST', 'DB_HOST'),
                secret('POSTGRES-PORT', 'DB_PORT'),
                secret('POSTGRES-DATABASE', 'DB_NAME'),
                secret('TEST-USER1-EMAIL', 'TEST_USER1_EMAIL'),
                secret('TEST-USER2-EMAIL', 'TEST_USER2_EMAIL'),
                secret('TEST-USER3-EMAIL', 'TEST_USER3_EMAIL'),
                secret('TEST-ADMIN1-EMAIL', 'TEST_ADMIN1_EMAIL'),
                secret('TEST-ADMIN2-EMAIL', 'TEST_ADMIN2_EMAIL'),
                secret('TEST-ADMIN3-EMAIL', 'TEST_ADMIN3_EMAIL'),
                secret('TEST-USERS-PASSWORD', 'TEST_USERS_PASSWORD'),
        ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [$class     : 'AzureKeyVaultSecret',
     secretType : 'Secret',
     name       : secretName,
     version    : '',
     envVariable: envVar
    ]
}

withPipeline(type, product, component) {
  loadVaultSecrets(secrets)
  enableSlackNotifications('#appreg-builds')

  after('functionalTest:aat') {
    stage('Functional Tests') {
      steps {
        script {
          try {
            sh 'yarn test:functional'
          } catch (Exception e) {
            echo "Tests failed: ${e.getMessage()}"
            echo "Continuing to archive artifacts..."
            currentBuild.result = 'UNSTABLE'
          }
          sh '''
            echo "=== Checking what was created ==="
            ls -la cypress/ || echo "No cypress directory"
            ls -la cypress/reports/ || echo "No reports directory"
            find cypress/reports -type f || echo "No files in reports"
          '''
        }
      }
      post {
        always {
          script {
            echo "Attempting to archive artifacts..."
            try {
              archiveArtifacts artifacts: 'cypress/reports/**/*.png', allowEmptyArchive: true
              archiveArtifacts artifacts: 'cypress/reports/**/*.html', allowEmptyArchive: true
              archiveArtifacts artifacts: 'cypress/reports/**/*.json', allowEmptyArchive: true
              echo "Artifacts archived successfully"
            } catch (Exception e) {
              echo "Failed to archive artifacts: ${e.getMessage()}"
            }
          }
          
          script {
            if (fileExists('cypress/reports/e2e/html')) {
              echo "HTML report directory exists, publishing..."
              publishHTML([
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports/e2e/html',
                reportFiles: '*.html',
                reportName: 'Test Report'
              ])
            } else {
              echo "WARNING: cypress/reports/e2e/html directory does not exist!"
              echo "Checking alternative locations..."
              sh 'find . -name "*.html" -path "*/cypress/*" || echo "No HTML files found"'
            }
          }
        }
      }
    }
  }

  syncBranchesWithMaster(branchesToSync)
}