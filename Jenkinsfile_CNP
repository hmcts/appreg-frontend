#!groovy

@Library("Infrastructure")

def type = "angular"
def product = "appreg"
def component = "frontend"

def branchesToSync = ['demo', 'ithc']

def secrets = [
    'appreg-${env}': [
        secret('POSTGRES-USER', 'DB_USER'),
        secret('POSTGRES-PASS', 'DB_PASSWORD'),
        secret('POSTGRES-HOST', 'DB_HOST'),
        secret('POSTGRES-PORT', 'DB_PORT'),
        secret('POSTGRES-DATABASE', 'DB_NAME'),
        secret('TEST-USER1-EMAIL', 'TEST_USER1_EMAIL'),
        secret('TEST-USER2-EMAIL', 'TEST_USER2_EMAIL'),
        secret('TEST-USER3-EMAIL', 'TEST_USER3_EMAIL'),
        secret('TEST-ADMIN1-EMAIL', 'TEST_ADMIN1_EMAIL'),
        secret('TEST-ADMIN2-EMAIL', 'TEST_ADMIN2_EMAIL'),
        secret('TEST-ADMIN3-EMAIL', 'TEST_ADMIN3_EMAIL'),
        secret('TEST-USERS-PASSWORD', 'TEST_USERS_PASSWORD'),
    ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [
        $class     : 'AzureKeyVaultSecret',
        secretType : 'Secret',
        name       : secretName,
        version    : '',
        envVariable: envVar
    ]
}

withPipeline(type, product, component) {

    loadVaultSecrets(secrets)
    enableSlackNotifications('#appreg-builds')

    before('functionalTest:dev') {
        try {
            echo "*** DEBUG: entering functionalTest:dev redirect URI hook ***"
            echo "DEBUG: TEST_URL=${env.TEST_URL ?: 'null'}"
            echo "DEBUG: SUBSCRIPTION_NAME=${env.SUBSCRIPTION_NAME ?: 'null'}"
            echo "DEBUG: ENVIRONMENT_NAME=${env.ENVIRONMENT_NAME ?: 'null'}"

            // Avoid MissingPropertyException if appObjectId isn't defined in this binding
            def appObjIdForLog = binding.hasVariable('appObjectId') ? appObjectId : null
            echo "DEBUG: appObjectId=${appObjIdForLog ?: 'MISSING'}"

            if (!env.TEST_URL) {
                echo "*** ERROR: TEST_URL missing from environment in functionalTest:dev hook ***"
                error("TEST_URL missing from environment")
            }

            if (!appObjIdForLog) {
                echo "*** ERROR: appObjectId is not available in this pipeline context ***"
                error("appObjectId missing from pipeline context")
            }

            echo "Whitelisting redirect URI for PR: ${env.TEST_URL}"

            def az = new uk.gov.hmcts.contino.azure.Az(this, env.SUBSCRIPTION_NAME)

            // Fetch current URIs via Graph
            echo "DEBUG: calling Graph to fetch current redirectUris for appObjectId=${appObjIdForLog}"
            def currentUrisJson = az.az(
                "rest --method GET --url 'https://graph.microsoft.com/v1.0/applications/${appObjIdForLog}' --query 'web.redirectUris' -o json"
            )

            echo "DEBUG: Graph GET returned (length=${currentUrisJson?.size() ?: 0})"
            echo "DEBUG: Graph GET preview=${currentUrisJson?.take(300) ?: 'null'}"

            echo "DEBUG: starting shell block to check/patch redirectUris"

            def rc = sh(
                script: """
                    set -xe
                    echo 'DEBUG [shell]: starting redirect URI update'
                    echo 'DEBUG [shell]: using TEST_URL=${env.TEST_URL}'
                    echo 'DEBUG [shell]: using appObjectId=${appObjIdForLog}'
                    echo 'DEBUG [shell]: using AZURE_CONFIG_DIR=/opt/jenkins/.azure-${env.SUBSCRIPTION_NAME}'

                    echo 'DEBUG [shell]: raw CURRENT JSON from Groovy (may be long):'
                    echo '${currentUrisJson}'

                    CURRENT='\\$(echo '${currentUrisJson}')'
                    echo "DEBUG [shell]: CURRENT=\\$CURRENT"

                    echo 'DEBUG [shell]: validating CURRENT is JSON array'
                    echo "\\$CURRENT" | jq -e 'type == "array"' > /dev/null
                    echo 'DEBUG [shell]: CURRENT is a JSON array'

                    echo 'DEBUG [shell]: checking if TEST_URL is already present'
                    if echo "\\$CURRENT" | jq -e --arg url "${env.TEST_URL}" 'any(. == \\$url)' > /dev/null; then
                      echo "DEBUG [shell]: URL already present in redirectUris, no update needed."
                    else
                      echo "DEBUG [shell]: URL not present, appending..."
                      UPDATED=\\$(echo "\\$CURRENT" | jq --arg url "${env.TEST_URL}" '. + [\\$url]')
                      echo "DEBUG [shell]: UPDATED=\\$UPDATED"

                      echo "DEBUG [shell]: building PATCH body"
                      BODY="{\\"web\\":{\\"redirectUris\\":\\$UPDATED}}"
                      echo "DEBUG [shell]: BODY=\\$BODY"

                      echo "DEBUG [shell]: calling az rest PATCH"
                      env AZURE_CONFIG_DIR=/opt/jenkins/.azure-${env.SUBSCRIPTION_NAME} az rest \\
                        --method PATCH \\
                        --url 'https://graph.microsoft.com/v1.0/applications/${appObjIdForLog}' \\
                        --headers 'Content-Type=application/json' \\
                        --body "\\$BODY"

                      echo "DEBUG [shell]: az rest PATCH completed"
                    fi

                    echo 'DEBUG [shell]: finished redirect URI shell logic'
                """,
                returnStatus: true
            )

            echo "DEBUG: redirect URI update shell exited with code ${rc}"

            if (rc != 0) {
                echo "WARN: redirect URI update failed with exit code ${rc} (pipeline will continue)"
                // If you want the build to hard-fail when this update fails, flip to:
                // error("Failed to update redirect URI, exit code ${rc}")
            }

            echo "*** DEBUG: leaving functionalTest:dev redirect URI hook ***"
        } catch (Throwable t) {
            echo "*** ERROR: redirect URI hook threw an exception: ${t.class.name}: ${t.message}"
            // Keep stack traces readable but useful
            t.stackTrace.take(20).each { st ->
                echo "  at ${st}"
            }
            throw t
        }
    }



    after('functionalTest:aat') {
        script {
            def testResult = sh(script: 'yarn test:functional', returnStatus: true)

            sh 'node cypress/scripts/generate-reports.js || true'

            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/**/*'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/screenshots/**/*.png'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/junit/**/*.xml'

            junit allowEmptyResults: true, testResults: 'cypress/reports/junit/**/*.xml'

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports/cucumber-html',
                reportFiles: 'index.html',
                reportName: 'Cucumber Report',
                reportTitles: 'Cucumber Test Report'
            ])

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports',
                reportFiles: 'mochawesome.html',
                reportName: 'Mochaware Report',
                reportTitles: 'Mochawesome Test Report'
            ])

            if (testResult != 0) {
                error("Smoke tests failed with exit code ${testResult}")
            }
        }
    }

    syncBranchesWithMaster(branchesToSync)
}
