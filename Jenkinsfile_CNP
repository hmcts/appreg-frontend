#!groovy

@Library("Infrastructure")

def type = "angular"
def product = "appreg"
def component = "frontend"

def branchesToSync = ['demo', 'ithc']

def secrets = [
    'appreg-${env}': [
        secret('POSTGRES-USER', 'DB_USER'),
        secret('POSTGRES-PASS', 'DB_PASSWORD'),
        secret('POSTGRES-HOST', 'DB_HOST'),
        secret('POSTGRES-PORT', 'DB_PORT'),
        secret('POSTGRES-DATABASE', 'DB_NAME'),
        secret('TEST-USER1-EMAIL', 'TEST_USER1_EMAIL'),
        secret('TEST-USER2-EMAIL', 'TEST_USER2_EMAIL'),
        secret('TEST-USER3-EMAIL', 'TEST_USER3_EMAIL'),
        secret('TEST-ADMIN1-EMAIL', 'TEST_ADMIN1_EMAIL'),
        secret('TEST-ADMIN2-EMAIL', 'TEST_ADMIN2_EMAIL'),
        secret('TEST-ADMIN3-EMAIL', 'TEST_ADMIN3_EMAIL'),
        secret('TEST-USERS-PASSWORD', 'TEST_USERS_PASSWORD'),
    ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [
        $class     : 'AzureKeyVaultSecret',
        secretType : 'Secret',
        name       : secretName,
        version    : '',
        envVariable: envVar
    ]
}

withPipeline(type, product, component) {

    loadVaultSecrets(secrets)
    enableSlackNotifications('#appreg-builds')

    before('functionalTest:dev') {
      echo "Setting up redirect URI for preview environment"

      if (!env.TEST_URL) {
        error("TEST_URL missing from environment")
      }

      def appObjectId = '20e4de40-7aee-45b1-895b-cb77546763dc'
      echo "Whitelisting redirect URI for PR: ${env.TEST_URL}"

      def rc
      withEnv([
        "APP_OBJECT_ID=${appObjectId}",
        "AZ_SUBSCRIPTION_NAME=${env.SUBSCRIPTION_NAME}",
        "TEST_URL=${env.TEST_URL}"
      ]) {
        rc = sh(
          script: """
            bash -lc '
              set -euo pipefail

              # --- Debug context (safe / minimal) ---
              echo "INFO: subscription=\${AZ_SUBSCRIPTION_NAME}"
              echo "INFO: appObjectId=\${APP_OBJECT_ID}"
              echo "INFO: testUrl=\${TEST_URL}"

              BASE_URL="\${TEST_URL%/}"
              LOGIN_CB="\${BASE_URL}/sso/login-callback"
              LOGOUT_CB="\${BASE_URL}/sso/logout-callback"

              echo "INFO: baseUrl=\${BASE_URL}"
              echo "INFO: loginCb=\${LOGIN_CB}"
              echo "INFO: logoutCb=\${LOGOUT_CB}"

              # --- GET current redirect URIs ---
              echo "INFO: fetching current redirectUris from Graph..."
              CURRENT="\$(env AZURE_CONFIG_DIR=/opt/jenkins/.azure-\${AZ_SUBSCRIPTION_NAME} az rest \\
                --method GET \\
                --url "https://graph.microsoft.com/v1.0/applications/\${APP_OBJECT_ID}" \\
                --query "web.redirectUris" -o json)"

              echo "INFO: current payload length=\${#CURRENT}"
              echo "INFO: current payload preview=\${CURRENT:0:250}"

              if [ "\$CURRENT" = "null" ] || [ -z "\$CURRENT" ]; then
                echo "WARN: current redirectUris empty/null; defaulting to []"
                CURRENT="[]"
              fi

              # Validate JSON early so jq failures are obvious
              if ! echo "\$CURRENT" | jq -e . >/dev/null 2>&1; then
                echo "ERROR: current redirectUris is not valid JSON" >&2
                echo "\$CURRENT" | head -c 1000 >&2 || true
                exit 3
              fi

              UPDATED="\$CURRENT"
              changed=0

              echo "INFO: checking login callback presence..."
              if echo "\$UPDATED" | jq -e --arg url "\$LOGIN_CB" '"'"'any(. == $url)'"'"' >/dev/null; then
                echo "INFO: login callback already present"
              else
                echo "INFO: adding login callback"
                UPDATED=\$(echo "\$UPDATED" | jq --arg url "\$LOGIN_CB" '"'"'. + [$url]'"'"')
                changed=1
              fi

              echo "INFO: checking logout callback presence..."
              if echo "\$UPDATED" | jq -e --arg url "\$LOGOUT_CB" '"'"'any(. == $url)'"'"' >/dev/null; then
                echo "INFO: logout callback already present"
              else
                echo "INFO: adding logout callback"
                UPDATED=\$(echo "\$UPDATED" | jq --arg url "\$LOGOUT_CB" '"'"'. + [$url]'"'"')
                changed=1
              fi

              if [ "\$changed" -eq 0 ]; then
                echo "INFO: no changes required; skipping PATCH"
                exit 0
              fi

              # Build body + preview
              BODY=\$(jq -cn --argjson uris "\$UPDATED" '"'"'{web:{redirectUris:$uris}}'"'"')
              echo "INFO: patch body preview=\$(echo "\$BODY" | head -c 250)"

              echo "INFO: performing Graph PATCH..."
              env AZURE_CONFIG_DIR=/opt/jenkins/.azure-\${AZ_SUBSCRIPTION_NAME} az rest \\
                --method PATCH \\
                --url "https://graph.microsoft.com/v1.0/applications/\${APP_OBJECT_ID}" \\
                --headers "Content-Type=application/json" \\
                --body "\$BODY" \\
                -o none

              echo "INFO: patch completed"
            '
          """,
          returnStatus: true
        )
      }

      if (rc != 0) {
        error("Redirect URI update failed (exit code ${rc})")
      }
    }

    after('functionalTest:aat') {
        script {
            def testResult = sh(script: 'yarn test:functional', returnStatus: true)

            sh 'node cypress/scripts/generate-reports.js || true'

            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/**/*'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/screenshots/**/*.png'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'cypress/reports/junit/**/*.xml'

            junit allowEmptyResults: true, testResults: 'cypress/reports/junit/**/*.xml'

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports/cucumber-html',
                reportFiles: 'index.html',
                reportName: 'Cucumber Report',
                reportTitles: 'Cucumber Test Report'
            ])

            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'cypress/reports',
                reportFiles: 'mochawesome.html',
                reportName: 'Mochaware Report',
                reportTitles: 'Mochawesome Test Report'
            ])

            if (testResult != 0) {
                error("Smoke tests failed with exit code ${testResult}")
            }
        }
    }

    syncBranchesWithMaster(branchesToSync)
}
