{
  "watch": ["server/**/*.ts", "src/types"],
  "ignore": [
    "src/app/**",
    "src/assets/**",
    "src/generated/**",
    "dist/**",
    ".angular/**"
  ],
  "ext": "ts,mts,js,mjs,json",
  "exec": "tsx server/dev-server.ts",
  "env": {
    "NODE_ENV": "development",
    "ALLOW_CONFIG_MUTATIONS": "true",
    "NG_DEV_SERVER": "http://localhost:4200"
  }
}
