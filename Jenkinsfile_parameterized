#!groovy

@Library("Infrastructure")

def type = "angular"
def product = "appreg"
def component = "frontend"

withParameterizedPipeline(type, product, component) {
  enableSlackNotifications('#appreg-builds')

  afterAlways('build') {
    yarnBuilder.yarn('rebuild puppeteer')
    yarnBuilder.yarn('build')
  }

  afterAlways('checkout') {
    sh "yarn install"
    echo 'Yarn install complete'
  }
}
