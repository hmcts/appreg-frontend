{
  "name": "appreg-frontend",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "ng": "ng",
    "start": "node dist/appreg-frontend/server/server.mjs",
    "start:dev": "nodemon --config nodemon.json",
    "lint": "stylelint **/*.scss -v -q && eslint . --ext .js,.ts --max-warnings 0 && prettier --check .",
    "lint:fix": "prettier --write . && eslint --fix .",
    "build": "ng build",
    "build:ssr": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:a11y": "jest --detectOpenHandles --forceExit -c jest.a11y.config.js --maxWorkers 15",
    "test:smoke": "NODE_TLS_REJECT_UNAUTHORIZED=0 jest -c jest.smoke.config.js",
    "test:functional": "echo 'NODE_TLS_REJECT_UNAUTHORIZED=0 cypress run'",
    "cichecks": "yarn build && yarn lint && yarn test && yarn test:routes && yarn test:a11y",
    "prepare": "husky install",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cucumber:report": "node cypress/scripts/generate-cucumber-report.js",
    "cypress:run:cucumber": "cypress run && yarn cucumber:report"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/platform-browser": "^20.1.0",
    "@angular/platform-browser-dynamic": "^20.1.0",
    "@angular/platform-server": "^20.1.0",
    "@angular/router": "^20.1.0",
    "@angular/ssr": "^20.1.5",
    "@azure/msal-node": "^3.7.1",
    "@hmcts/info-provider": "^1.2.3",
    "@hmcts/nodejs-healthcheck": "^1.8.6",
    "@hmcts/nodejs-logging": "^4.0.4",
    "@hmcts/properties-volume": "^1.2.0",
    "@types/helmet": "^4.0.0",
    "@types/lodash": "^4.14.197",
    "applicationinsights": "^2.7.0",
    "config": "^4.1.0",
    "cookie-parser": "^1.4.7",
    "cross-fetch": "^4.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "glob": "^11.0.3",
    "govuk-frontend": "^5.11.1",
    "helmet": "^7.0.0",
    "http-proxy-middleware": "^3.0.5",
    "lodash": "^4.17.21",
    "pa11y": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^11.1.0",
    "zone.js": "0.15"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.1.1",
    "@angular-eslint/eslint-plugin-template": "^20.1.1",
    "@angular-eslint/template-parser": "^20.1.1",
    "@angular/build": "^20.1.5",
    "@angular/cli": "^20.1.5",
    "@angular/compiler-cli": "^20.1.0",
    "@badeball/cypress-cucumber-preprocessor": "^22.2.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.5",
    "@eslint/compat": "^1.3.2",
    "@types/axe-core": "^3.0.6",
    "@types/config": "^3.3.5",
    "@types/cookie-parser": "^1",
    "@types/express": "^5.0.1",
    "@types/express-session": "^1",
    "@types/govuk-frontend": "^5",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.17.19",
    "@types/pa11y": "^5.3.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "cypress": "^14.5.4",
    "cypress-mochawesome-reporter": "^4.0.2",
    "cypress-multi-reporters": "^2.0.5",
    "esbuild": "^0.25.9",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-cypress": "^5.1.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.0.5",
    "jest-preset-angular": "^15.0.0",
    "mocha": "^11.7.1",
    "mocha-junit-reporter": "^2.2.1",
    "multiple-cucumber-html-reporter": "^3.9.3",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "typescript": "~5.9.0"
  },
  "packageManager": "yarn@4.8.1"
}