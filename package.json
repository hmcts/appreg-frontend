{
  "name": "appreg-frontend",
  "version": "0.0.0",
  "volta": {
    "node": "20.11.1",
    "yarn": "4.8.1"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "node scripts/copy-govuk-assets.ts && ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "stylelint **/*.scss -v -q && eslint . --ext .js,.ts && prettier --check .",
    "lint:fix": "prettier --write . .github && eslint --fix .",
    "test": "ng test",
    "test:smoke": "ng test --include 'src/test/smoke/**/*.ts' --watch=false --browsers=ChromeHeadless"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.13",
    "@angular/common": "^18.2.13",
    "@angular/compiler": "^18.2.13",
    "@angular/core": "^18.2.13",
    "@angular/forms": "^18.2.13",
    "@angular/platform-browser": "^18.2.13",
    "@angular/platform-browser-dynamic": "^18.2.13",
    "@angular/router": "^18.2.13",
    "govuk-frontend": "^5.10.0",
    "rxjs": "~6.6.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.19",
    "@angular-eslint/eslint-plugin": "^20.1.1",
    "@angular-eslint/eslint-plugin-template": "^20.1.1",
    "@angular-eslint/schematics": "^20.1.1",
    "@angular/cli": "18.2.20",
    "@angular/compiler-cli": "^18.2.13",
    "@eslint/compat": "^1.3.1",
    "@types/fs-extra": "^11",
    "@types/govuk-frontend": "^5.9.0",
    "@types/jasmine": "~3.8.0",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.3",
    "fs-extra": "^11.3.0",
    "jasmine-core": "~3.8.0",
    "jsonc-parser": "^3.3.1",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.23.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "typescript": "~5.4.5"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0"
  }
}
