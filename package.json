{
  "name": "appreg-frontend",
  "version": "0.0.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "ng": "ng",
    "api:clear": "rimraf src/generated/openapi",
    "api:fetch-unpack": "node scripts/fetch-unpack-openapi.cjs",
    "api:validate": "openapi-generator-cli validate -i tools/openapi/vendor/openapi/openapi.yaml",
    "api:generate": "openapi-generator-cli generate -c tools/openapi/generator-config.yaml",
    "api:bundle": "redocly bundle tools/openapi/vendor/openapi/openapi.yaml -o tools/dist/openapi.bundled.yaml",
    "api:all": "yarn api:clear && yarn api:fetch-unpack && yarn api:validate && yarn api:bundle && yarn api:generate",
    "start": "node dist/appreg-frontend/server/server.mjs",
    "start:dev": "nodemon --config nodemon.json",
    "start:mock": "docker compose up -d wiremock",
    "lint": "yarn api:all && stylelint **/*.scss -v -q && eslint . --ext .js,.ts --max-warnings 0 && prettier --check .",
    "lint:fix": "prettier --write . && eslint --fix .",
    "build": "ng build",
    "build:ssr": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:a11y": "jest --detectOpenHandles --forceExit -c jest.a11y.config.js --maxWorkers 15",
    "test:smoke": "jest -c jest.smoke.config.js",
    "test:functional": "cypress run --spec 'cypress/e2e/features/smoke/**/*.feature'; node cypress/scripts/generate-reports.js; mkdir -p functional-output && cp -r cypress/reports/* functional-output/ || true",
    "test:nightly": "cypress run --browser chrome || CODE=$? ; node cypress/scripts/generate-reports.js ; mkdir -p functional-output && cp -r cypress/reports/* functional-output/ ; exit ${CODE:-0}",
    "test:nightly:smoke": "CYPRESS_TAGS=@smoke cypress run --browser chrome || CODE=$? ; node cypress/scripts/generate-reports.js ; mkdir -p functional-output/smoke && cp -r cypress/reports/* functional-output/smoke/ ; exit ${CODE:-0}",
    "test:nightly:regression": "CYPRESS_TAGS=@regression cypress run --browser chrome || CODE=$? ; node cypress/scripts/generate-reports.js ; mkdir -p functional-output/regression && cp -r cypress/reports/* functional-output/regression/ ; exit ${CODE:-0}",
    "test:nightly:combine": "mkdir -p functional-output/combined && jrm functional-output/combined/test-result.xml \"functional-output/smoke/junit/*.xml\" \"functional-output/regression/junit/*.xml\"",
    "cichecks": "yarn api:all && yarn build && yarn lint && yarn test && yarn test:routes && yarn test:a11y",
    "prepare": "husky install",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run; node cypress/scripts/generate-reports.js",
    "branch:dry-run": "yarn node .github/branch-retention/branch-retention.mjs --mode dry-run",
    "branch:enforce": "yarn node .github/branch-retention/branch-retention.mjs --mode enforce"
  },
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.1",
    "@azure/msal-node": "^3.7.1",
    "@hmcts/info-provider": "^1.2.3",
    "@hmcts/nodejs-healthcheck": "^1.8.6",
    "@hmcts/nodejs-logging": "^4.0.4",
    "@hmcts/properties-volume": "^1.2.0",
    "@jest/globals": "^30.2.0",
    "@ministryofjustice/frontend": "^6.0.0",
    "@octokit/rest": "^22.0.0",
    "applicationinsights": "^2.7.0",
    "concurrently": "^9.2.1",
    "config": "^4.1.0",
    "connect-history-api-fallback": "^2.0.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cross-fetch": "^4.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "glob": "^11.0.3",
    "govuk-frontend": "^5.12.0",
    "helmet": "^7.0.0",
    "http-proxy-middleware": "^3.0.5",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lodash": "^4.17.21",
    "minimatch": "^10.0.3",
    "pa11y": "^9.0.0",
    "redis": "^5.8.3",
    "rimraf": "^6.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^11.1.0",
    "yaml": "^2.8.1",
    "zone.js": "0.16"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.1.1",
    "@angular-eslint/eslint-plugin-template": "^20.1.1",
    "@angular-eslint/template-parser": "^20.1.1",
    "@angular/build": "^20.3.1",
    "@angular/cli": "^20.3.1",
    "@angular/compiler-cli": "^20.3.0",
    "@badeball/cypress-cucumber-preprocessor": "^23.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.5",
    "@eslint/compat": "^1.3.2",
    "@openapitools/openapi-generator-cli": "^2.23.4",
    "@redocly/cli": "^2.1.4",
    "@types/adm-zip": "^0",
    "@types/axe-core": "^3.0.6",
    "@types/config": "^3.3.5",
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/cookie-parser": "^1",
    "@types/express": "^5.0.1",
    "@types/express-session": "^1",
    "@types/govuk-frontend": "^5",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/lodash": "^4.14.197",
    "@types/node": "^20.17.19",
    "@types/pa11y": "^5.3.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "adm-zip": "^0.5.16",
    "axe-core": "^4.10.3",
    "cypress": "15.7.0",
    "cypress-axe": "^1.7.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "cypress-multi-reporters": "^2.0.5",
