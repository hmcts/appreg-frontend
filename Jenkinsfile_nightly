#!groovy

properties([
  pipelineTriggers([cron('H 07 * * 1-5')]),
  copyArtifactPermission('*'),
  parameters([
    booleanParam(name: 'Smoke', defaultValue: true, description: 'Run smoke tests'),
    booleanParam(name: 'Regression', defaultValue: true, description: 'Run regression tests'),
  ])
])
@Library('Infrastructure')
def type = 'angular'
def product = 'appreg'
def component = 'frontend'
def secrets = [
  'appreg-${env}': [
    secret('POSTGRES-USER', 'DB_USER'),
    secret('POSTGRES-PASS', 'DB_PASSWORD'),
    secret('POSTGRES-HOST', 'DB_HOST'),
    secret('POSTGRES-PORT', 'DB_PORT'),
    secret('POSTGRES-DATABASE', 'DB_NAME'),
    secret('TEST-USER1-EMAIL', 'TEST_USER1_EMAIL'),
    secret('TEST-USER2-EMAIL', 'TEST_USER2_EMAIL'),
    secret('TEST-USER3-EMAIL', 'TEST_USER3_EMAIL'),
    secret('TEST-ADMIN1-EMAIL', 'TEST_ADMIN1_EMAIL'),
    secret('TEST-ADMIN2-EMAIL', 'TEST_ADMIN2_EMAIL'),
    secret('TEST-ADMIN3-EMAIL', 'TEST_ADMIN3_EMAIL'),
    secret('TEST-USERS-PASSWORD', 'TEST_USERS_PASSWORD'),
  ]
]
static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [$class     : 'AzureKeyVaultSecret',
   secretType : 'Secret',
   name       : secretName,
   version    : '',
   envVariable: envVar
  ]
}
def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

withNightlyPipeline(type, product, component) {
  loadVaultSecrets(secrets)
  enableSlackNotifications('#appreg-builds')
  
  env.TEST_URL = 'https://appreg.staging.apps.hmcts.net/'

  afterAlways('DependencyCheckNightly') {
    stage('Connectivity Test') {
      catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE', message: 'Connectivity test issues') {
        sh "./cypress/scripts/connectivity/test-connectivity.sh ${env.TEST_URL}"
      }
    }
    
    echo 'Smoke: ' + params.Smoke
    echo 'Regression: ' + params.Regression

    if (params.Smoke) {
      stage('Smoke Tests - Chrome & Edge') {
        parallel(
          'Chrome': {
            catchError(buildResult: 'FAILURE', stageResult: 'FAILURE', message: 'Smoke tests (Chrome) failed') {
              try {
                yarnBuilder.yarn('test:nightly:smoke:chrome')
              } finally {
                archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/chrome/smoke/**/*'
                junit allowEmptyResults: true, testResults: 'functional-output/chrome/smoke/junit/**/*.xml'
              }
            }
          },
          'Edge': {
            catchError(buildResult: 'FAILURE', stageResult: 'FAILURE', message: 'Smoke tests (Edge) failed') {
              try {
                yarnBuilder.yarn('test:nightly:smoke:edge')
              } finally {
                archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/edge/smoke/**/*'
                junit allowEmptyResults: true, testResults: 'functional-output/edge/smoke/junit/**/*.xml'
              }
            }
          }
        )
      }
    }

    if (params.Regression) {
      stage('Regression Tests - Chrome & Edge') {
        parallel(
          'Chrome': {
            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE', message: 'Regression tests (Chrome) failed') {
              try {
                yarnBuilder.yarn('test:nightly:regression:chrome --env TAGS=\'not @ignore and not @broken\'')
              } finally {
                archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/chrome/regression/**/*'
                junit allowEmptyResults: true, testResults: 'functional-output/chrome/regression/junit/**/*.xml'
              }
            }
          },
          'Edge': {
            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE', message: 'Regression tests (Edge) failed') {
              try {
                yarnBuilder.yarn('test:nightly:regression:edge --env TAGS=\'not @ignore and not @broken\'')
              } finally {
                archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/edge/regression/**/*'
                junit allowEmptyResults: true, testResults: 'functional-output/edge/regression/junit/**/*.xml'
              }
            }
          }
        )
      }
      
      stage('Generate Browser Reports') {
        parallel(
          'Chrome Report': {
            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE', message: 'Chrome report generation failed') {
              try {
                // Generate Chrome-only HTML report
                yarnBuilder.yarn('test:nightly:regression:html:cucumber:chrome')
              } finally {
                // Publish the Chrome HTML report
                publishHTML target: [
                  allowMissing         : true,
                  alwaysLinkToLastBuild: true,
                  keepAll              : true,
                  reportDir            : 'functional-output/chrome/regression/cucumber-html',
                  reportFiles          : 'detailed-test-report.html',
                  reportName           : 'Application Register - Chrome Test Report'
                ]
              }
            }
          },
          'Edge Report': {
            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE', message: 'Edge report generation failed') {
              try {
                // Generate Edge-only HTML report
                yarnBuilder.yarn('test:nightly:regression:html:cucumber:edge')
              } finally {
                // Publish the Edge HTML report
                publishHTML target: [
                  allowMissing         : true,
                  alwaysLinkToLastBuild: true,
                  keepAll              : true,
                  reportDir            : 'functional-output/edge/regression/cucumber-html',
                  reportFiles          : 'detailed-test-report.html',
                  reportName           : 'Application Register - Edge Test Report'
                ]
              }
            }
          }
        )
      }
      
      stage('Generate Combined Report') {
        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE', message: 'Combined report generation failed') {
          try {
            // Generate combined HTML report from both Chrome and Edge results
            yarnBuilder.yarn('test:nightly:regression:html:cucumber')
          } finally {
            // Publish the combined HTML report
            publishHTML target: [
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : 'functional-output/regression/cucumber-html',
              reportFiles          : 'detailed-test-report.html',
              reportName           : 'Application Register - Combined Report (Chrome + Edge)'
            ]
            
            // Archive all outputs
            archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/regression/**/*'
          }
        }
      }
    }
  }
}