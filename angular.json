{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "appreg-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "type": "component"
        },
        "@schematics/angular:service": {
          "type": "service"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "stylePreprocessorOptions": {
              "includePaths": ["./"]
            },
            "assets": [
              {
                "glob": "**/*",
                "input": "src/public",
                "output": ""
              },
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              },
              {
                "glob": "**/*",
                "input": "node_modules/@ministryofjustice/frontend/moj/assets/images",
                "output": "assets/images"
              },
              {
                "glob": "**/*",
                "input": "node_modules/govuk-frontend/dist/govuk/assets",
                "output": "assets"
              },
              {
                "glob": "govuk-frontend.min.js",
                "input": "node_modules/govuk-frontend/dist/govuk",
                "output": "javascripts"
              }
            ],
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "styles": ["src/styles.scss"],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "server/server.ts"
            },
            "allowedCommonJsDependencies": [
              "jspdf",
              "@babel/runtime",
              "canvg",
              "core-js",
              "raf",
              "rgbcolor",
              "html2canvas",
              "fflate",
              "dompurify"
            ]
          },
          "configurations": {
            "production": {
              "optimization": {
                "styles": {
                  "inlineCritical": false,
                  "minify": true
                }
              },
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "900kB",
                  "maximumError": "1.2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kB",
                  "maximumError": "10kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "build-spa": {
          "defaultConfiguration": "development",
          "builder": "@angular/build:application",
          "options": {
            "stylePreprocessorOptions": {
              "includePaths": ["./"]
            },
            "assets": [
              { "glob": "**/*", "input": "src/public", "output": "" },
              { "glob": "**/*", "input": "src/assets", "output": "assets" },
              {
                "glob": "**/*",
                "input": "node_modules/@ministryofjustice/frontend/moj/assets/images",
                "output": "assets/images"
              },
              {
                "glob": "**/*",
                "input": "node_modules/govuk-frontend/dist/govuk/assets",
                "output": "assets"
              },
              {
                "glob": "govuk-frontend.min.js",
                "input": "node_modules/govuk-frontend/dist/govuk",
                "output": "javascripts"
              }
            ],
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "styles": ["src/styles.scss"],
            "outputMode": "static",
            "allowedCommonJsDependencies": [
              "jspdf",
              "@babel/runtime",
              "canvg",
              "core-js",
              "raf",
              "rgbcolor",
              "html2canvas",
              "fflate",
              "dompurify"
            ]
          },
          "configurations": {
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "appreg-frontend:build:production"
            },
            "development": {
              "buildTarget": "appreg-frontend:build-spa:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {}
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
